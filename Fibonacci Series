class Fibonacci {
    int n;
    Fibonacci(int num) {
        n = num;
    }
    void printSeries() {
        int a = 0, b = 1, c;
        System.out.print(a + " " + b);
        for(int i = 2; i < n; i++) {
            c = a + b;
            System.out.print(" " + c);
            a = b;
            b = c;
        }
    }
    public static void main(String[] args) {
        Fibonacci obj = new Fibonacci(10);
        obj.printSeries();
    }
}

