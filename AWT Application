import java.awt.*;
import java.awt.event.WindowAdapter;
import java.awt.event.WindowEvent;

public class AWTImageTextExample extends Frame {

    private Image img;

    public AWTImageTextExample() {
        
        img = Toolkit.getDefaultToolkit().getImage("example.jpg");
        setTitle("AWT Image and Text Example");
        setSize(500, 400);
        setVisible(true);
        addWindowListener(new WindowAdapter() {
            public void windowClosing(WindowEvent we) {
                System.exit(0);
            }
        });
    }

   
    public void paint(Graphics g) {
  
        g.setFont(new Font("Arial", Font.BOLD, 20));
        g.setColor(Color.BLUE);
        g.drawString("Hello, this is AWT!", 100, 100);
        g.drawImage(img, 100, 150, this);
    }

    public static void main(String[] args) {
        new AWTImageTextExample();
    }
}
