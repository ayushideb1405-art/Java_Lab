class MaxThree {
    int a, b, c;
    MaxThree(int x, int y, int z) {
        a = x; b = y; c = z;
    }
    void findMax() {
        int max = (a > b) ? (a > c ? a : c) : (b > c ? b : c);
        System.out.println("Maximum: " + max);
    }
    public static void main(String[] args) {
        MaxThree obj = new MaxThree(10, 25, 15);
        obj.findMax();
    }
}

